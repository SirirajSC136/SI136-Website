rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasAdminClaim() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function hasActiveAdminRecord() {
      return isSignedIn()
        && request.auth.token.email is string
        && firestore.exists(/databases/(default)/documents/admin_users/$(request.auth.token.email.lower()))
        && firestore.get(/databases/(default)/documents/admin_users/$(request.auth.token.email.lower())).data.active == true;
    }

    function isAdmin() {
      return hasAdminClaim() || hasActiveAdminRecord();
    }

    // Public-ish files for signed-in students
    match /public/{allPaths=**} {
      allow read: if isSignedIn();
      allow write, delete: if isAdmin();
    }

    // Admin uploads and private assets
    match /admin/{allPaths=**} {
      allow read, write, delete: if isAdmin();
    }

    // Interactive media: signed-in students can read, admins can manage writes.
    match /admin/interactive/{allPaths=**} {
      allow read: if isSignedIn();
      allow write, delete: if isAdmin();
    }

    // Catch-all deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
