rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Custom/overlay course tree
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /topics/{topicId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();

        match /items/{itemId} {
          allow read: if isSignedIn();
          allow write: if isAdmin();
        }
      }
    }

    // Interactive resources
    match /interactive_contents/{interactiveId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /interactive_attempts/{attemptId} {
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.uid;
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.uid);
      allow update, delete: if isAdmin();
    }

    match /flashcard_sessions/{sessionId} {
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.uid;
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.uid);
      allow update: if isSignedIn() && request.auth.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    // Explicit deny-all fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
